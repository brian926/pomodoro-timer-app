{
  "name": "pomo-timer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter ./frontend --filter ./backend dev",
    "build": "pnpm --filter ./shared build && pnpm --filter ./frontend --filter ./backend build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
